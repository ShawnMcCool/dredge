{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dredge",
  "mainBinaryName": "dredge",
  "version": "0.7.0",
  "identifier": "dev.shawn.dredge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "dredge",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Shawn McCool",
    "linux": {
      "deb": {
        "depends": [
          "librubberband2",
          "libpipewire-0.3-0"
        ],
        "recommends": [
          "ffmpeg",
          "uv",
          "demucs"
        ],
        "files": {
          "/usr/bin/dredged": "../../../target/release/dredged",
          "/usr/bin/dredge-analyze": "../../../scripts/analyze",
          "/usr/bin/dredge-enable-ml": "../../../scripts/dredge-enable-ml",
          "/usr/bin/dredge-doctor": "../../../scripts/dredge-doctor",
          "/usr/lib/dredge/analyze_impl.py": "../../../scripts/analyze_impl.py",
          "/usr/lib/dredge/songformer_impl.py": "../../../scripts/songformer_impl.py"
        }
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
