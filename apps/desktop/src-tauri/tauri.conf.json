{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "earworm",
  "mainBinaryName": "earworm",
  "version": "0.1.0",
  "identifier": "dev.shawn.earworm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "earworm",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Shawn McCool",
    "linux": {
      "deb": {
        "depends": ["librubberband2", "libpipewire-0.3-0"],
        "recommends": ["uv", "demucs"],
        "files": {
          "/usr/bin/earwormd": "../../../target/release/earwormd",
          "/usr/bin/earworm-analyze": "../../../scripts/analyze",
          "/usr/bin/earworm-enable-ml": "../../../scripts/earworm-enable-ml",
          "/usr/lib/earworm/analyze_impl.py": "../../../scripts/analyze_impl.py",
          "/usr/lib/earworm/songformer_impl.py": "../../../scripts/songformer_impl.py"
        }
      }
    }
  }
}
