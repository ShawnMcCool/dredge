#!/usr/bin/env bash
set -euo pipefail

# Deterministic release mechanics for dredge. The only step left to a human
# or model is writing the user-facing release notes; everything else — version
# math, release-safety checks, changelog insertion, commits, tag, push, and
# post-tag verification — is mechanical and lives here.
#
# Subcommands:
#
#   prepare <major|minor|patch>
#       Read-only. Prints the release facts (last tag, current/next version,
#       suggested notes-file path, commits since last tag) in KEY=VALUE form
#       for the caller to consume. Mutates nothing.
#
#   check [--fast] [--allow-schema-change]
#       Release-safety gate. Confirms main is current, flags risky SQLite
#       schema edits, and (unless --fast) runs the production artifact build
#       so a tag never publishes a release that doesn't compile. Exits
#       non-zero with a FAILED list when something is wrong.
#
#   release <major|minor|patch> --notes <file> [--dry-run]
#       The mutation chain: insert the notes into CHANGELOG.md under a
#       "## v<next> — <date>" header, commit, bump the version in
#       tauri.conf.json (the source of truth), commit, push main, tag from
#       tauri.conf.json, push the tag. The notes file must contain ONLY the
#       body (no version header). --dry-run prints what would happen.
#
#   verify [<version>] [--timeout <seconds>]
#       Polls the GitHub release for the tag (default: version in
#       tauri.conf.json) until the .deb + tarball + SHA256SUMS are present,
#       failing fast if the release workflow run concluded in failure.
#
#   aur [<version>] [--pkgrel <n>] [--ci] [--dry-run]
#       Update the AUR packages for a published release (default: the version
#       in tauri.conf.json). Pulls the prebuilt tarball checksum from the
#       release SHA256SUMS, bumps pkgver in both PKGBUILDs (source `dredge` +
#       prebuilt `dredge-looper-bin`), regenerates .SRCINFO, verifies the
#       prebuilt source resolves, commits the bump to main, then pushes each
#       package to its AUR remote. Needs makepkg and an unlocked AUR SSH key.
#       Run after `verify` confirms the release. --pkgrel sets the release
#       number (default 1) for a packaging-only re-push at the same version.
#       --ci skips the repo commit (the release.yml `aur` job runs this in an
#       Arch container; the in-repo PKGBUILDs stay templates there).
#
# Tests and lint are deliberately NOT run here — run `just check` before
# shipping; this script gates the *release path*, not code quality.

cd "$(dirname "$0")/.."

CONF="apps/desktop/src-tauri/tauri.conf.json"
SCHEMA="crates/practice/src/store.rs"

banner() { echo "==> $1"; }
fail() { echo "FAILED: $1" >&2; exit 1; }

conf_version() {
  python3 -c "import json;print(json.load(open('$CONF'))['version'])"
}

set_conf_version() {
  python3 - "$1" <<PY
import json, sys
p = "$CONF"
d = json.load(open(p))
d["version"] = sys.argv[1]
with open(p, "w") as f:
    json.dump(d, f, indent=2)
    f.write("\n")
PY
}

last_tag() {
  git tag --sort=-v:refname | head -n1
}

# Bump pkgver + pkgrel in a PKGBUILD in place.
set_pkgbuild_version() {
  sed -i -E -e "s/^pkgver=.*/pkgver=$2/" -e "s/^pkgrel=.*/pkgrel=$3/" "$1"
}

# Replace the single quoted sha256sums entry in a PKGBUILD (prebuilt only; the
# source package keeps SKIP and is never passed here).
set_pkgbuild_sha() {
  sed -i -E "s/^sha256sums=\('.*'\)/sha256sums=('$2')/" "$1"
}

next_version() {
  local level="$1" current="$2" major minor patch
  IFS=. read -r major minor patch <<<"${current%%-*}"
  case "$level" in
    major) echo "$((major + 1)).0.0" ;;
    minor) echo "${major}.$((minor + 1)).0" ;;
    patch) echo "${major}.${minor}.$((patch + 1))" ;;
    *) fail "bump level must be major|minor|patch, got: $level" ;;
  esac
}

# On main and not behind origin. dredge keeps main local, so a missing or
# unreachable origin/main is tolerated (we're simply ahead, ready to push);
# we only refuse when we can confirm the local tip is stale.
require_main_and_current() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)
  [ "$branch" = "main" ] || fail "on branch '$branch' — releases ship from main"

  if GIT_SSH_COMMAND='ssh -o BatchMode=yes' git fetch --quiet origin main 2>/dev/null; then
    if [ -n "$(git log --oneline HEAD..origin/main 2>/dev/null)" ]; then
      fail "main is behind origin/main — pull/rebase first; refusing to ship from a stale tip"
    fi
  else
    echo "  (note: couldn't reach origin/main — shipping from local main)" >&2
  fi
}

# ---------------------------------------------------------------- prepare

cmd_prepare() {
  local level="${1:-}"
  [ -n "$level" ] || fail "usage: scripts/ship prepare <major|minor|patch>"

  require_main_and_current

  local current next tag
  current=$(conf_version)
  next=$(next_version "$level" "$current")
  tag=$(last_tag)

  echo "LAST_TAG=${tag:-(none)}"
  echo "CURRENT_VERSION=$current"
  echo "NEXT_VERSION=$next"
  echo "NEXT_TAG=v$next"
  echo "DATE=$(date +%F)"
  echo "NOTES_FILE=/tmp/dredge-notes-v$next.md"

  if [ -n "$(git status --porcelain)" ]; then
    echo "WORKING_TREE=dirty (commit before release)"
  else
    echo "WORKING_TREE=clean"
  fi

  if [ -n "$tag" ]; then
    echo "COMMITS_SINCE_${tag}:"
    git log --pretty=format:"- %s" "${tag}..HEAD"
  else
    echo "COMMITS (no prior tag):"
    git log --pretty=format:"- %s"
  fi
  echo
}

# ------------------------------------------------------------------ check

cmd_check() {
  local fast=false allow_schema=false
  for arg in "$@"; do
    case "$arg" in
      --fast) fast=true ;;
      --allow-schema-change) allow_schema=true ;;
      *) fail "unknown flag for check: $arg" ;;
    esac
  done

  local tag failures=()
  tag=$(last_tag)
  banner "Release-safety check${tag:+ (diffing against $tag)}"

  require_main_and_current

  banner "SQLite schema contract"
  # store.rs owns the embedded schema + PRAGMA user_version migrations. The
  # safe-evolution rule is additive only: a NEW version block, never an edit
  # to an existing one — editing a shipped block silently diverges existing
  # users' databases. Any touch since the last tag is flagged for review.
  if [ -n "$tag" ]; then
    local schema_diff
    schema_diff=$(git diff --name-only "${tag}..HEAD" -- "$SCHEMA")
    if [ -n "$schema_diff" ] && [ "$allow_schema" = false ]; then
      git --no-pager diff "${tag}..HEAD" -- "$SCHEMA"
      failures+=("$SCHEMA touched since $tag — confirm the change is a NEW user_version block (not an edit to a shipped one), then re-run with --allow-schema-change")
    fi
  else
    echo "  (no prior tag — skipping schema diff)"
  fi

  banner "Changelog sanity"
  if [ ! -f CHANGELOG.md ]; then
    echo "  (no CHANGELOG.md yet — 'release' will create it)"
  elif ! head -1 CHANGELOG.md | grep -q '^# Changelog'; then
    failures+=("CHANGELOG.md is malformed (must start with '# Changelog')")
  fi

  if [ "$fast" = false ]; then
    banner "Production artifact build (just artifacts)"
    if just artifacts; then
      local ver
      ver=$(conf_version)
      ls dist/*.deb >/dev/null 2>&1 || failures+=("artifact missing: dist/*.deb")
      [ -f "dist/dredge-${ver}-x86_64-linux.tar.gz" ] || failures+=("artifact missing: dist/dredge-${ver}-x86_64-linux.tar.gz")
      [ -f dist/SHA256SUMS ] || failures+=("artifact missing: dist/SHA256SUMS")
    else
      failures+=("just artifacts failed — the tag would publish a broken release")
    fi
  else
    banner "Skipping artifact build (--fast)"
  fi

  if [ "${#failures[@]}" -gt 0 ]; then
    echo
    echo "RELEASE SAFETY CHECK FAILED"
    for failure in "${failures[@]}"; do
      echo "  - $failure"
    done
    exit 1
  fi

  echo
  echo "RELEASE SAFETY CHECK PASSED"
}

# ---------------------------------------------------------------- release

cmd_release() {
  local level="${1:-}" notes="" dry_run=false
  [ -n "$level" ] || fail "usage: scripts/ship release <major|minor|patch> --notes <file> [--dry-run]"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --notes) notes="${2:-}"; shift 2 ;;
      --dry-run) dry_run=true; shift ;;
      *) fail "unknown flag for release: $1" ;;
    esac
  done

  [ -n "$notes" ] || fail "release requires --notes <file>"
  [ -s "$notes" ] || fail "notes file is missing or empty: $notes"
  grep -q '^## v[0-9]' "$notes" && \
    fail "notes file contains a version header — provide the body only; the script adds '## v<version> — <date>'"

  require_main_and_current

  if [ "$dry_run" = false ] && [ -n "$(git status --porcelain)" ]; then
    fail "working tree dirty — commit feature work before releasing"
  fi

  local current next date_today
  current=$(conf_version)
  next=$(next_version "$level" "$current")
  date_today=$(date +%F)

  git rev-parse "v$next" >/dev/null 2>&1 && fail "tag v$next already exists"

  banner "Releasing v$next (from $current, $level bump)"

  # Insert the new entry above the newest existing "## v" header, creating the
  # file (with a "# Changelog" title) when this is the first release.
  local header="## v$next — $date_today"
  local changelog_new
  if [ -f CHANGELOG.md ]; then
    changelog_new=$(awk -v header="$header" -v notes_file="$notes" '
      !inserted && /^## v[0-9]/ {
        print header; print ""
        while ((getline line < notes_file) > 0) print line
        print ""
        inserted = 1
      }
      { print }
      END {
        if (!inserted) {
          print ""; print header; print ""
          while ((getline line < notes_file) > 0) print line
        }
      }
    ' CHANGELOG.md)
  else
    changelog_new=$(printf '# Changelog\n\nAll notable user-facing changes to dredge, newest first.\n\n%s\n\n%s' \
      "$header" "$(cat "$notes")")
  fi

  if [ "$dry_run" = true ]; then
    banner "[dry-run] CHANGELOG.md head would become:"
    head -30 <<<"$changelog_new"
    banner "[dry-run] $CONF version line would become: \"$next\""
    banner "[dry-run] then: commit changelog, commit bump, push main, tag v$next, push tag"
    return 0
  fi

  banner "Writing CHANGELOG.md entry"
  printf '%s\n' "$changelog_new" > CHANGELOG.md
  git add CHANGELOG.md
  git commit -m "docs: changelog for v$next"

  banner "Bumping $CONF to $next"
  set_conf_version "$next"
  [ "$(conf_version)" = "$next" ] || fail "version bump did not take — inspect $CONF"
  git add "$CONF"
  git commit -m "chore(release): v$next"

  # The tag follows tauri.conf.json exactly (release.yml triggers on v* tags).
  local version
  version=$(conf_version)
  push_or_explain "v$version"

  echo
  echo "RELEASED v$version — the tag triggers .github/workflows/release.yml."
  echo "Run: scripts/ship verify $version"
}

# Push main + the tag, but degrade gracefully: dredge's main is kept local and
# the SSH key is often locked, so a push failure is expected and recoverable —
# the commits and tag exist locally, so we tell the user how to finish by hand.
push_or_explain() {
  local tag="$1"
  banner "Tagging $tag"
  git tag "$tag"

  banner "Pushing main + $tag"
  if git push origin main && git push origin "$tag"; then
    return 0
  fi

  echo >&2
  echo "PUSH FAILED (SSH key locked, or offline?). The commits and tag exist" >&2
  echo "locally — unlock your key and finish with:" >&2
  echo "    git push origin main && git push origin $tag" >&2
  echo "(do not force-push; the tag triggers the release workflow on arrival)" >&2
  exit 1
}

# ----------------------------------------------------------------- verify

cmd_verify() {
  local version="" timeout=1800
  while [ $# -gt 0 ]; do
    case "$1" in
      --timeout) timeout="${2:-1800}"; shift 2 ;;
      *) version="$1"; shift ;;
    esac
  done
  [ -n "$version" ] || version=$(conf_version)
  local tag="v$version"

  banner "Verifying GitHub release $tag (timeout ${timeout}s)"
  local deadline=$((SECONDS + timeout))

  while [ $SECONDS -lt $deadline ]; do
    local run_state run_status run_conclusion run_url
    run_state=$(gh run list --workflow=release.yml --branch "$tag" --limit 1 \
      --json status,conclusion,url \
      --jq '(.[0].status // "none") + " " + (.[0].conclusion // "") + " " + (.[0].url // "")' 2>/dev/null) || run_state="unknown"
    read -r run_status run_conclusion run_url <<<"$run_state"

    if [ "$run_conclusion" = "failure" ] || [ "$run_conclusion" = "cancelled" ]; then
      fail "release workflow $run_conclusion — ${run_url:-check: gh run list --workflow=release.yml}"
    fi

    local assets
    assets=$(gh release view "$tag" --json assets --jq '.assets[].name' 2>/dev/null || true)
    if [ -n "$assets" ]; then
      local missing=()
      echo "$assets" | grep -q "\.deb$" || missing+=(".deb")
      echo "$assets" | grep -q "dredge-${version}-x86_64-linux.tar.gz" || missing+=("linux tarball")
      echo "$assets" | grep -qx "SHA256SUMS" || missing+=("SHA256SUMS")
      if [ "${#missing[@]}" -eq 0 ]; then
        echo "RELEASE VERIFIED — assets present:"
        echo "$assets" | sed 's/^/  /'
        return 0
      fi
    fi

    echo "  waiting… (workflow: ${run_status:-unknown})"
    sleep 30
  done

  fail "timed out after ${timeout}s waiting for $tag assets — check: gh run list --workflow=release.yml"
}

# -------------------------------------------------------------------- aur

SRC_DIR="packaging/aur/dredge"
BIN_DIR="packaging/aur/dredge-looper-bin"

cmd_aur() {
  local version="" pkgrel=1 dry_run=false ci=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --pkgrel) pkgrel="${2:?--pkgrel needs a value}"; shift 2 ;;
      --dry-run) dry_run=true; shift ;;
      --ci) ci=true; shift ;;
      -*) fail "unknown flag for aur: $1" ;;
      *) version="$1"; shift ;;
    esac
  done
  [ -n "$version" ] || version=$(conf_version)
  local tag="v$version"

  command -v makepkg >/dev/null 2>&1 || fail "makepkg not found — run 'aur' on an Arch box"
  command -v gh >/dev/null 2>&1 || fail "gh not found — needed to read the release SHA256SUMS"
  [ -f "$SRC_DIR/PKGBUILD" ] && [ -f "$BIN_DIR/PKGBUILD" ] \
    || fail "PKGBUILDs not found — expected $SRC_DIR and $BIN_DIR"

  banner "Updating AUR packages to $version-$pkgrel"

  # The prebuilt's source is the release tarball; its checksum is authoritative
  # in the release SHA256SUMS, so read it from there rather than recomputing.
  local tarball="dredge-${version}-x86_64-linux.tar.gz"
  local tmp; tmp=$(mktemp -d)
  gh release download "$tag" -p SHA256SUMS -D "$tmp" >/dev/null 2>&1 \
    || fail "no SHA256SUMS on release $tag — publish/verify it first (scripts/ship verify $version)"
  local sha
  sha=$(awk -v f="$tarball" '$2 == f {print $1}' "$tmp/SHA256SUMS")
  rm -rf "$tmp"
  [ -n "$sha" ] || fail "no checksum for $tarball in release $tag SHA256SUMS"
  banner "$tarball sha256=$sha"

  set_pkgbuild_version "$SRC_DIR/PKGBUILD" "$version" "$pkgrel"
  set_pkgbuild_version "$BIN_DIR/PKGBUILD" "$version" "$pkgrel"
  set_pkgbuild_sha "$BIN_DIR/PKGBUILD" "$sha"

  banner "Regenerating .SRCINFO"
  ( cd "$SRC_DIR" && makepkg --printsrcinfo > .SRCINFO )
  ( cd "$BIN_DIR" && makepkg --printsrcinfo > .SRCINFO )

  banner "Verifying the prebuilt source resolves (makepkg --verifysource)"
  if ! ( cd "$BIN_DIR" && makepkg --verifysource >/dev/null 2>&1 ); then
    ( cd "$BIN_DIR" && rm -rf src pkg "$tarball" )
    fail "verifysource failed for dredge-looper-bin — release tarball/checksum mismatch for $tag?"
  fi
  ( cd "$BIN_DIR" && rm -rf src pkg "$tarball" )

  if [ "$dry_run" = true ]; then
    banner "[dry-run] PKGBUILD / .SRCINFO changes:"
    git --no-pager diff -- "$SRC_DIR" "$BIN_DIR"
    banner "[dry-run] then: commit the bump, push main, push both packages to the AUR"
    git checkout -- "$SRC_DIR" "$BIN_DIR"
    return 0
  fi

  if [ "$ci" = true ]; then
    banner "CI mode — not committing to the repo; publishing to the AUR only"
  elif git diff --quiet -- "$SRC_DIR" "$BIN_DIR"; then
    banner "PKGBUILDs already at $version-$pkgrel — publishing as-is"
  else
    banner "Committing the bump"
    git add "$SRC_DIR" "$BIN_DIR"
    git commit -m "packaging(aur): bump to $version"
    git push origin main \
      || echo "  (couldn't push main — commit exists locally; finish with: git push origin main)" >&2
  fi

  aur_publish dredge "$version" "$pkgrel"
  aur_publish dredge-looper-bin "$version" "$pkgrel"

  echo
  echo "AUR UPDATED — dredge + dredge-looper-bin at $version-$pkgrel."
}

# Push one package's PKGBUILD + .SRCINFO to its AUR repo. The AUR default branch
# is master (the local default is main), so we clone, copy the in-repo files in,
# and push HEAD:master. A no-op when the AUR already matches.
aur_publish() {
  local pkg="$1" version="$2" pkgrel="$3"
  local dir="packaging/aur/$pkg"
  local work; work=$(mktemp -d)

  banner "Publishing $pkg to the AUR"
  git clone --quiet "ssh://aur@aur.archlinux.org/$pkg.git" "$work" \
    || fail "clone $pkg.git failed — is the AUR SSH key unlocked? (ssh aur@aur.archlinux.org help)"
  cp "$dir/PKGBUILD" "$dir/.SRCINFO" "$work/"
  git -C "$work" add PKGBUILD .SRCINFO
  if git -C "$work" diff --cached --quiet; then
    echo "  $pkg: already up to date on the AUR"
    rm -rf "$work"
    return 0
  fi
  git -C "$work" commit -q -m "$pkg $version-$pkgrel"
  if ! git -C "$work" push --quiet origin HEAD:master; then
    rm -rf "$work"
    fail "push $pkg to the AUR failed — unlock the 1Password SSH key and retry: scripts/ship aur $version"
  fi
  rm -rf "$work"
  echo "  $pkg: published $version-$pkgrel"
}

# ------------------------------------------------------------------- main

usage() {
  # Print the leading comment block (the subcommand reference) up to the first
  # `cd` line, so it stays correct as subcommands are added.
  sed -n '4,/^cd /p' "$0" | sed -e '/^cd /d' -e 's/^# \{0,1\}//'
  exit 1
}

case "${1:-}" in
  prepare) shift; cmd_prepare "$@" ;;
  check) shift; cmd_check "$@" ;;
  release) shift; cmd_release "$@" ;;
  verify) shift; cmd_verify "$@" ;;
  aur) shift; cmd_aur "$@" ;;
  *) usage ;;
esac
