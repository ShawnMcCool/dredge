#!/usr/bin/env bash
# dredge audio analysis wrapper.
#
# Bootstraps its own uv venv on first run (~/.local/share/dredge/analyze-venv,
# override with $DREDGE_ANALYZE_VENV), then execs analyze_impl.py inside it.
#
# Contract: stdout carries EXACTLY ONE JSON object (the analysis result);
# every diagnostic — including bootstrap output — goes to stderr.
set -euo pipefail

VENV="${DREDGE_ANALYZE_VENV:-$HOME/.local/share/dredge/analyze-venv}"
PY="$VENV/bin/python"

# Portable absolute-dir of this script. macOS ships BSD readlink, which has no
# -f, so resolve symlinks by hand instead of `readlink -f`.
SOURCE="$0"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"

if [ ! -x "$PY" ] || ! "$PY" -c "import beat_this" >/dev/null 2>&1; then
  echo "dredge-analyze: bootstrapping venv at $VENV (first run — downloads torch, may take minutes)" >&2
  uv venv --python 3.12 "$VENV" 1>&2
  uv pip install --python "$PY" \
    "beat_this @ git+https://github.com/CPJKU/beat_this" \
    torch soundfile librosa einops rotary-embedding-torch 1>&2
  echo "dredge-analyze: venv ready" >&2
fi

# analyze_impl.py sits next to this wrapper in a repo checkout, or under
# /usr/lib/dredge when installed from a package (the wrapper lands on PATH as
# /usr/bin/dredge-analyze, away from its impls). songformer_impl.py is resolved
# by analyze_impl.py relative to its own location, so co-location is enough.
IMPL=""
for d in "$HERE" "${DREDGE_IMPL_DIR:-}" /usr/lib/dredge /usr/local/lib/dredge /opt/homebrew/lib/dredge; do
  [ -n "$d" ] || continue
  if [ -f "$d/analyze_impl.py" ]; then IMPL="$d/analyze_impl.py"; break; fi
done
[ -n "$IMPL" ] || { echo "dredge-analyze: analyze_impl.py not found (looked in $HERE, \$DREDGE_IMPL_DIR, /usr/lib/dredge, /usr/local/lib/dredge, /opt/homebrew/lib/dredge)" >&2; exit 1; }

exec "$PY" "$IMPL" "$@"
